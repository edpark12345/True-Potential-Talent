---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const SIGNUP_ENDPOINT = 'https://formspree.io/f/your-form-id';
---
<BaseLayout
  title="Free 14-Day Confidence Guide"
  description="A free 14-day guide with one small daily prompt to build confidence and clarity — gently, one step at a time. No cost, no obligation."
  path="/coaching/14-day-guide"
>
  <PageHero kicker="Free guide" title="The Free 14-Day Guide" lede="One small, practical step each day for two weeks — designed to build your confidence and clarity gently, without overwhelm. Completely free.">
  </PageHero>

  <section class="section">
    <div class="container guide-grid">
      <div class="fade-up">
        <h2>What you’ll get</h2>
        <ul class="tick-list">
          {['A short daily prompt, delivered to your inbox','A practical 5-minute exercise each day','Gentle, encouraging tone — no pressure','Tools you can keep using long after day 14'].map((i) => (
            <li><span class="cred-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg></span>{i}</li>
          ))}
        </ul>
        <p style="margin-top:20px;color:var(--muted)">It’s a lovely way to get a feel for how I work — and a genuinely useful fortnight in its own right.</p>
      </div>

      <form class="card signup-card fade-up" id="guide-form" novalidate data-endpoint={SIGNUP_ENDPOINT}>
        <h3>Get the guide free</h3>
        <p style="color:var(--muted);font-size:.9rem;margin-bottom:6px">Enter your details and I’ll send day one straight away.</p>
        <div class="field">
          <label for="g-name">First name</label>
          <input id="g-name" name="name" type="text" autocomplete="given-name" required aria-describedby="gerr-name" />
          <span class="error" id="gerr-name" data-error-for="name"></span>
        </div>
        <div class="field">
          <label for="g-email">Email</label>
          <input id="g-email" name="email" type="email" autocomplete="email" required aria-describedby="gerr-email" />
          <span class="error" id="gerr-email" data-error-for="email"></span>
        </div>
        <button type="submit" class="btn btn-gold btn-lg btn-arrow" data-submit style="width:100%;justify-content:center">Send me the guide</button>
        <p class="form-status" data-status role="status" aria-live="polite"></p>
        <p class="privacy-note">No spam, ever. Unsubscribe any time. See our <a href="/privacy">privacy policy</a>.</p>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('guide-form') as HTMLFormElement | null;
  if (form) {
    const status = form.querySelector('[data-status]') as HTMLElement;
    const btn = form.querySelector('[data-submit]') as HTMLButtonElement;
    const endpoint = form.dataset.endpoint || '';
    const showError = (name: string, msg: string) => {
      const el = form.querySelector(`[data-error-for="${name}"]`);
      if (el) el.textContent = msg;
      form.querySelector(`[name="${name}"]`)?.setAttribute('aria-invalid', 'true');
    };
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      form.querySelectorAll('.error').forEach((el) => (el.textContent = ''));
      form.querySelectorAll('[aria-invalid]').forEach((el) => el.removeAttribute('aria-invalid'));
      status.className = 'form-status';
      status.textContent = '';
      const name = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
      const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
      let ok = true;
      if (!name) { showError('name', 'Please enter your first name.'); ok = false; }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showError('email', 'Please enter a valid email.'); ok = false; }
      if (!ok) return;
      btn.disabled = true; btn.textContent = 'Sending…';
      if (endpoint.includes('your-form-id')) {
        setTimeout(() => {
          status.className = 'form-status ok';
          status.textContent = 'You’re in! Day one is on its way (connect an email endpoint to go live).';
          form.reset(); btn.disabled = false; btn.textContent = 'Send me the guide';
        }, 700);
        return;
      }
      try {
        const res = await fetch(endpoint, { method: 'POST', headers: { Accept: 'application/json' }, body: new FormData(form) });
        if (!res.ok) throw new Error();
        status.className = 'form-status ok';
        status.textContent = 'You’re in! Check your inbox for day one.';
        form.reset();
      } catch {
        status.className = 'form-status err';
        status.textContent = 'Something went wrong — please try again shortly.';
      } finally {
        btn.disabled = false; btn.textContent = 'Send me the guide';
      }
    });
  }
</script>

<style>
  .guide-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
  .tick-list { display: grid; gap: 14px; margin-top: 8px; }
  .tick-list li { display: flex; gap: 12px; align-items: center; }
  .cred-check { width: 24px; height: 24px; border-radius: 50%; background: var(--sage-light); border: 1px solid var(--border); display: grid; place-items: center; flex-shrink: 0; }
  .cred-check svg { width: 11px; height: 11px; color: var(--forest); }
  .signup-card { display: grid; gap: 14px; background: linear-gradient(160deg, var(--cream), var(--sage-light)); }
  .field { display: grid; gap: 6px; }
  .field label { font-size: .82rem; font-weight: 600; color: var(--forest); }
  .field input { font: inherit; padding: 12px 14px; border: 1.5px solid var(--border); border-radius: var(--r-sm); background: var(--white); width: 100%; transition: border-color var(--t-fast), box-shadow var(--t-fast); }
  .field input:focus { outline: none; border-color: var(--fern); box-shadow: 0 0 0 3px rgba(61,122,92,.15); }
  .error { font-size: .78rem; color: #b3261e; min-height: 1em; }
  .form-status { font-size: .9rem; }
  .form-status.ok { color: var(--forest); font-weight: 600; }
  .form-status.err { color: #b3261e; font-weight: 600; }
  .privacy-note { font-size: .76rem; color: var(--muted); }
  .privacy-note a { color: var(--gold); text-decoration: underline; }
  @media (max-width: 820px) { .guide-grid { grid-template-columns: 1fr; gap: 32px; } }
</style>
