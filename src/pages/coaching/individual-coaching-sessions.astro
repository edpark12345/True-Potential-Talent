---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBand from '../../components/CtaBand.astro';
---
<BaseLayout
  title="Individual Coaching Sessions"
  description="Flexible one-to-one coaching sessions tailored to you — work on confidence, communication, leadership or whatever matters most, at your own pace."
  path="/coaching/individual-coaching-sessions"
>
  <PageHero kicker="1:1 coaching" title="Individual Coaching Sessions" lede="Flexible, focused one-to-one sessions for when you want support on your own terms — book one when you need it, or build your own rhythm.">
    <div class="btn-row" style="margin-top:24px">
      <a class="btn btn-forest btn-arrow" href="/contact">Book a session</a>
    </div>
  </PageHero>

  <section class="section">
    <div class="container two-col">
      <div class="fade-up">
        <h2>Coaching that fits your life</h2>
        <p class="lede">Not everyone needs a full programme. Individual sessions give you a focused, confidential space to think clearly, work through a challenge, and leave with a concrete next step.</p>
        <p style="margin-top:16px;color:var(--muted)">Bring whatever is live for you — a tricky decision, a confidence wobble, a difficult relationship at work, or a goal you can’t quite get moving. We’ll work on it together.</p>
      </div>
      <div class="card fade-up highlight-card">
        <h3>Common reasons people book</h3>
        <ul class="tick-list">
          {['Preparing for a big conversation or interview','Building confidence before a new role','Working through a specific challenge','Regular accountability and thinking space','A check-in between bigger pieces of work'].map((i) => (
            <li><span class="cred-check"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg></span>{i}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <CtaBand title="Book your first session" text="Start with a free discovery call so we can make sure it’s the right fit for you." />
</BaseLayout>

<style>
  .two-col { display: grid; grid-template-columns: 1.1fr 1fr; gap: 48px; align-items: center; }
  .highlight-card { background: var(--sage-light); }
  .tick-list { display: grid; gap: 12px; margin-top: 14px; }
  .tick-list li { display: flex; gap: 12px; align-items: center; }
  .cred-check { width: 24px; height: 24px; border-radius: 50%; background: var(--white); border: 1px solid var(--border); display: grid; place-items: center; flex-shrink: 0; }
  .cred-check svg { width: 11px; height: 11px; color: var(--forest); }
  @media (max-width: 820px) { .two-col { grid-template-columns: 1fr; gap: 28px; } }
</style>
