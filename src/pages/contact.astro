---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';

// Replace with your Formspree (or similar) endpoint to receive enquiries by email.
const FORM_ENDPOINT = 'https://formspree.io/f/your-form-id';
---
<BaseLayout
  title="Contact"
  description="Get in touch with True Potential Training to book a discovery call or ask about coaching and team training. Online and in-person across the UK."
  path="/contact"
>
  <PageHero kicker="Contact" title="Let’s start a conversation." lede="Whether you’re ready to book or just exploring, drop a message below or book a discovery call. I read every enquiry personally." />

  <section class="section">
    <div class="container contact-grid">
      <div class="contact-info fade-up">
        <h2>Get in touch</h2>
        <p class="lede" style="margin-bottom:24px">No pressure, no hard sell — just a warm conversation about where you’d like to grow.</p>
        <ul class="contact-list">
          <li>
            <span class="ci-label">Email</span>
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </li>
          <li>
            <span class="ci-label">Discovery call</span>
            <a href={site.calendly} target="_blank" rel="noopener">Book a free 30-minute call →</a>
          </li>
          <li>
            <span class="ci-label">Where</span>
            <span>{site.location}</span>
          </li>
        </ul>
        <div class="contact-give">{site.banner}</div>
      </div>

      <form class="contact-form card fade-up" id="contact-form" novalidate data-endpoint={FORM_ENDPOINT}>
        <div class="field">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" autocomplete="name" required />
          <span class="error" data-error-for="name"></span>
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" autocomplete="email" required />
          <span class="error" data-error-for="email"></span>
        </div>
        <div class="field">
          <label for="topic">I’m interested in</label>
          <select id="topic" name="topic">
            <option>Coaching (1:1)</option>
            <option>Team training</option>
            <option>The free 14-day guide</option>
            <option>Something else</option>
          </select>
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required></textarea>
          <span class="error" data-error-for="message"></span>
        </div>
        <button type="submit" class="btn btn-forest btn-lg btn-arrow" data-submit>Send message</button>
        <p class="form-status" data-status role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    const status = form.querySelector('[data-status]') as HTMLElement;
    const btn = form.querySelector('[data-submit]') as HTMLButtonElement;
    const endpoint = form.dataset.endpoint || '';

    const showError = (name: string, msg: string) => {
      const el = form.querySelector(`[data-error-for="${name}"]`);
      if (el) el.textContent = msg;
    };
    const clearErrors = () => form.querySelectorAll('.error').forEach((e) => (e.textContent = ''));

    const validate = () => {
      clearErrors();
      let ok = true;
      const name = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
      const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
      const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();
      if (!name) { showError('name', 'Please enter your name.'); ok = false; }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showError('email', 'Please enter a valid email.'); ok = false; }
      if (message.length < 10) { showError('message', 'Please add a little more detail.'); ok = false; }
      return ok;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.className = 'form-status';
      status.textContent = '';
      if (!validate()) return;

      btn.disabled = true;
      btn.textContent = 'Sending…';

      // If no real endpoint configured yet, simulate success gracefully.
      if (endpoint.includes('your-form-id')) {
        setTimeout(() => {
          status.className = 'form-status ok';
          status.textContent = 'Thanks! Your message is ready — connect a form endpoint to start receiving enquiries.';
          form.reset();
          btn.disabled = false;
          btn.textContent = 'Send message';
        }, 700);
        return;
      }

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        if (res.ok) {
          status.className = 'form-status ok';
          status.textContent = 'Thank you — your message has been sent. I’ll be in touch soon.';
          form.reset();
        } else {
          throw new Error('Request failed');
        }
      } catch {
        status.className = 'form-status err';
        status.textContent = 'Something went wrong. Please email hello@truepotentialtraining.net instead.';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Send message';
      }
    });
  }
</script>

<style>
  .contact-grid { display: grid; grid-template-columns: 1fr 1.1fr; gap: 56px; align-items: start; }
  .contact-list { display: grid; gap: 20px; margin: 8px 0 28px; }
  .contact-list li { display: grid; gap: 4px; }
  .ci-label { font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; color: var(--gold); font-weight: 700; }
  .contact-list a:hover { color: var(--gold); }
  .contact-give { background: var(--sage-light); border: 1px solid var(--border); border-radius: var(--r); padding: 16px 18px; font-size: .85rem; color: var(--forest); }
  .contact-form { display: grid; gap: 18px; }
  .field { display: grid; gap: 6px; }
  .field label { font-size: .82rem; font-weight: 600; color: var(--forest); }
  .field input, .field select, .field textarea {
    font: inherit; padding: 12px 14px; border: 1.5px solid var(--border); border-radius: var(--r-sm);
    background: var(--cream); color: var(--ink); transition: border-color var(--t-fast), box-shadow var(--t-fast); width: 100%;
  }
  .field input:focus, .field select:focus, .field textarea:focus {
    outline: none; border-color: var(--fern); box-shadow: 0 0 0 3px rgba(61,122,92,.15);
  }
  .field textarea { resize: vertical; }
  .error { font-size: .78rem; color: #b3261e; min-height: 1em; }
  .form-status { font-size: .9rem; margin-top: 4px; }
  .form-status.ok { color: var(--forest); font-weight: 600; }
  .form-status.err { color: #b3261e; font-weight: 600; }
  @media (max-width: 820px) { .contact-grid { grid-template-columns: 1fr; gap: 36px; } }
</style>
