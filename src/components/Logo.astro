---
// Brand logo — the original True Potential Training tree mark.
// `light` adds a white chip so the mark stays crisp on dark backgrounds.
interface Props {
  size?: number;
  light?: boolean;
}
const { size = 44, light = false } = Astro.props;
---
<span class:list={['logo-mark', { chip: light }]} style={`--s:${size}px`}>
  <img src="/logo.png" alt="" width={size} height={size} loading="eager" decoding="async" />
</span>

<style>
  .logo-mark { display: inline-grid; place-items: center; flex-shrink: 0; }
  .logo-mark img { width: var(--s); height: var(--s); object-fit: contain; display: block; }
  .logo-mark.chip {
    background: var(--cream);
    border-radius: 50%;
    padding: calc(var(--s) * 0.12);
    box-shadow: 0 4px 14px rgba(0,0,0,.18);
  }
  .logo-mark.chip img { width: calc(var(--s) * 0.84); height: calc(var(--s) * 0.84); }
</style>
