---
// Decorative line-art tree motif — echoes the brand watermark.
interface Props { class?: string; }
const { class: cls = '' } = Astro.props;
---
<svg class={`tree-motif ${cls}`} viewBox="0 0 400 460" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
  <g stroke="currentColor" stroke-width="1.3" stroke-linecap="round" opacity="0.9">
    <!-- trunk -->
    <path d="M200 460 V250" />
    <!-- primary boughs -->
    <path d="M200 270 C160 240 140 200 120 150" />
    <path d="M200 270 C240 240 260 200 280 150" />
    <path d="M200 250 C175 210 160 170 150 110" />
    <path d="M200 250 C225 210 240 170 250 110" />
    <path d="M200 240 V70" />
    <!-- secondary branches -->
    <path d="M150 180 C120 165 100 150 78 120" />
    <path d="M250 180 C280 165 300 150 322 120" />
    <path d="M168 150 C150 130 140 110 132 84" />
    <path d="M232 150 C250 130 260 110 268 84" />
    <path d="M200 150 C185 130 178 112 172 92" />
    <path d="M200 150 C215 130 222 112 228 92" />
  </g>
  <g fill="currentColor" opacity="0.55">
    <circle cx="120" cy="150" r="6" /><circle cx="280" cy="150" r="6" />
    <circle cx="150" cy="110" r="5" /><circle cx="250" cy="110" r="5" />
    <circle cx="78" cy="120" r="4.5" /><circle cx="322" cy="120" r="4.5" />
    <circle cx="132" cy="84" r="4" /><circle cx="268" cy="84" r="4" />
    <circle cx="172" cy="92" r="4" /><circle cx="228" cy="92" r="4" />
    <circle cx="200" cy="70" r="6.5" />
  </g>
</svg>

<style>
  .tree-motif { width: 100%; height: auto; color: var(--fern); }
</style>
