---
import TreeMotif from './TreeMotif.astro';
interface Props {
  kicker?: string;
  title: string;
  lede?: string;
}
const { kicker, title, lede } = Astro.props;
---
<section class="page-hero" aria-labelledby="ph-title">
  <div class="page-hero-motif" aria-hidden="true"><TreeMotif /></div>
  <div class="container">
    {kicker && <span class="eyebrow">{kicker}</span>}
    <h1 id="ph-title">{title}</h1>
    {lede && <p class="lede page-hero-lede">{lede}</p>}
    <slot />
  </div>
  <div class="page-hero-watermark" aria-hidden="true"></div>
</section>

<style>
  .page-hero {
    position: relative; overflow: hidden;
    padding: var(--sp-lg) 0 var(--sp-md);
    background:
      radial-gradient(ellipse 60% 70% at 92% 6%, rgba(200,217,194,.5), transparent),
      var(--cream);
  }
  .page-hero > .container { position: relative; z-index: 1; }
  .page-hero-motif {
    position: absolute; top: -50px; right: -20px; width: clamp(220px, 26vw, 360px);
    color: var(--fern); opacity: .08; pointer-events: none; z-index: 0;
  }
  .eyebrow { margin-bottom: 18px; }
  .page-hero h1 { font-size: clamp(2.4rem, 5vw, 4rem); max-width: 18ch; }
  .page-hero-lede { margin-top: 18px; max-width: 60ch; }
  .page-hero-watermark {
    position: absolute; right: -60px; top: -40px; width: 320px; height: 320px;
    background: radial-gradient(circle, rgba(61,122,92,.10), transparent 70%);
    border-radius: 50%; pointer-events: none;
  }
</style>
