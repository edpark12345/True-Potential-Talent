---
import Logo from './Logo.astro';
import { site } from '../data/site';
import { training } from '../data/training';
const year = new Date().getFullYear();
---
<footer class="site-footer on-dark" role="contentinfo">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label={`${site.name} — Home`}>
        <Logo size={48} light />
        <span>
          <span class="fb-name">{site.name}</span>
          <span class="fb-sub">{site.tagline}</span>
        </span>
      </a>
      <p class="footer-blurb">
        Warm, practical coaching and training that helps women and teams grow with confidence,
        communicate with clarity, and lead with purpose.
      </p>
      <p class="footer-give">{site.banner}</p>
    </div>

    <div class="footer-col">
      <h4>Coaching</h4>
      <ul>
        <li><a href="/coaching/8-week-course">8-Week Programme</a></li>
        <li><a href="/coaching/individual-coaching-sessions">Individual Sessions</a></li>
        <li><a href="/coaching/14-day-guide">Free 14-Day Guide</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Training</h4>
      <ul>
        {training.slice(0, 6).map((c) => <li><a href={`/training/${c.slug}`}>{c.title}</a></li>)}
        <li><a href="/training">All courses →</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Company</h4>
      <ul>
        <li><a href="/about">About Lynne</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="/privacy">Privacy Policy</a></li>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {year} {site.name}. All rights reserved.</p>
    <p>{site.location}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: linear-gradient(165deg, var(--forest-2), var(--forest) 55%, #0e2018);
    color: rgba(255,255,255,.78); padding: var(--sp-xl) 0 var(--sp-md);
    margin-top: auto;
  }
  .footer-grid {
    display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 48px;
    padding-bottom: var(--sp-lg); border-bottom: 1px solid rgba(255,255,255,.12);
  }
  .footer-logo { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
  .fb-name { display: block; font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 600; color: #fff; }
  .fb-sub { display: block; font-size: .63rem; letter-spacing: .13em; text-transform: uppercase; color: var(--gold-lt); }
  .footer-blurb { font-size: .9rem; line-height: 1.6; max-width: 38ch; margin-bottom: 16px; }
  .footer-give { font-size: .82rem; color: var(--gold-lt); font-weight: 500; max-width: 38ch; }
  .footer-col h4 { color: #fff; margin-bottom: 14px; font-size: .85rem; letter-spacing: .04em; }
  .footer-col li { margin-bottom: 9px; }
  .footer-col a { font-size: .88rem; transition: color var(--t-fast); }
  .footer-col a:hover { color: var(--gold-lt); }
  .footer-bottom {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px;
    padding-top: var(--sp-md); font-size: .8rem; color: rgba(255,255,255,.6);
  }
  @media (max-width: 860px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; }
  }
</style>
